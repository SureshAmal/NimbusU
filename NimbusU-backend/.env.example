# ── Core ────────────────────────────────────────────────────────────────
SECRET_KEY=your-production-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,your-custom-domain.com

# ── PostgreSQL (Railway provides these automatically) ───────────────────
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-db-host.railway.internal
DB_PORT=5432

# ── CORS (your Vercel frontend URL) ────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── MinIO / S3 Storage ─────────────────────────────────────────────────
# For production, use AWS S3 or a managed S3-compatible service
MINIO_ENDPOINT=https://your-s3-endpoint.com
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=nimbusu-media
